[rotom_api]
base_url         = "https://rotom.example.com"
fetch_timeout_ms = 30000

[polling]
check_interval_ms      = 300000
device_timeout_minutes = 10

[retry]
initial_delay_ms = 1000
max_delay_ms     = 30000
max_retries      = 3

[concurrency]
max_concurrent_jobs = 10

[circuit_breaker]
threshold = 5
reset_ms  = 60000

[scripts]
path                 = "../../oci.sh"
restart_arg          = "-rsc"
update_arg           = "-usc"
new_arg              = "-new"
update_all_arg       = "-u"
timeout_ms           = 300000
restart_threshold    = 2
kill_grace_period_ms = 5000

[logging]
format = "json"
level  = "info"

[metrics]
host = "127.0.0.1"
port = 9090

[shutdown]
grace_period_ms = 60000
